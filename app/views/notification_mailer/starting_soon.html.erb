<h1 style="margin:0 0 12px;font-size:22px;font-weight:700;line-height:1.3;color:#1a1a2e;">Your workshop starts in <%= Workshop::JOIN_WINDOW.inspect %>!</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.55;color:#3a3a4a;">
  <% if @record %>
    <strong><%= @record.title %></strong> is about to begin. The Zoom link is live on the workshop page. Click the button below to join.
  <% else %>
    A workshop you RSVP'd to is about to begin.
  <% end %>
</p>

<% if @record %>
  <div style="margin:24px 0 4px;">
    <a href="<%= workshop_url(@record) %>" style="display:inline-block;padding:11px 22px;background:#1a1a2e;color:#ffffff;text-decoration:none;border-radius:999px;font-weight:600;font-size:14px;line-height:1;">Join the workshop</a>
  </div>
<% end %>
