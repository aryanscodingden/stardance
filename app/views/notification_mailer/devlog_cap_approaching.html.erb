<% project_title = @record&.title %>
<% unposted_time = @notification.unposted_time_text %>

<h1 style="margin:0 0 12px;font-size:22px;font-weight:700;line-height:1.3;color:#1a1a2e;">
  Time to post a devlog!
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.55;color:#3a3a4a;">
  You've built up <strong><%= unposted_time %></strong> on
  <% if project_title.present? %><strong><%= project_title %></strong><% else %>your project<% end %>
  since your last devlog.
</p>

<p style="margin:0 0 24px;font-size:15px;line-height:1.55;color:#3a3a4a;">
  Only up to <%= Post::ShipEvent::MAX_PAYOUT_HOURS_PER_DEVLOG %> hours per devlog counts toward your payout when you ship- post a devlog now to make sure your time is counted.
</p>

<% if @record %>
  <div style="margin:24px 0 4px;">
    <a href="<%= project_url(@record) %>" style="display:inline-block;padding:11px 22px;background:#1a1a2e;color:#ffffff;text-decoration:none;border-radius:999px;font-weight:600;font-size:14px;line-height:1;">Post a devlog</a>
  </div>
<% end %>
