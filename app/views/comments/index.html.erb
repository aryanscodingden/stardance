<%# Echo the requesting frame's id so the response matches whichever card opened the modal. %>
<%= turbo_frame_tag(request.headers["Turbo-Frame"].presence || dom_id(@commentable, :comments)) do %>
  <div class="comment-modal__replies-list">
    <% if @comments.any? %>
      <%= render partial: "comments/comment", collection: @comments %>
    <% else %>
      <p class="comment-modal__replies-empty">No replies yet — be the first to reply.</p>
    <% end %>
  </div>
<% end %>
