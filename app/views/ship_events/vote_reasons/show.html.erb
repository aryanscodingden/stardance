<% content_for :title, "Rating reasons" %>

<main class="vote-reasons-page">
  <header class="vote-reasons-page__header">
    <div>
      <p class="vote-reasons-page__eyebrow">Payout review</p>
      <h1 class="vote-reasons-page__title">Rating reasons</h1>
    </div>

    <% if @ship_event.payout_review_deadline %>
      <dl class="vote-reasons-page__summary" aria-label="Payout snapshot">
        <div class="vote-reasons-page__summary-item">
          <dt>Locked payout</dt>
          <dd><%= @ship_event.estimated_payout.to_i %> stardust</dd>
        </div>
        <div class="vote-reasons-page__summary-item">
          <dt>Review until</dt>
          <dd><%= l(@ship_event.payout_review_deadline, format: :short) %></dd>
        </div>
        <div class="vote-reasons-page__summary-item">
          <dt>Incorrect flag cost</dt>
          <dd><%= Vote::FLAG_COST %> stardust</dd>
        </div>
      </dl>
    <% end %>
  </header>

  <% if @votes.any? %>
    <ol class="vote-reasons-page__list">
      <% @votes.each.with_index(1) do |vote, index| %>
        <li class="vote-reasons-page__item">
          <div class="vote-reasons-page__item-header">
            <span class="vote-reasons-page__number"><%= index %></span>
            <h2 class="vote-reasons-page__item-title">Reason <%= index %></h2>
          </div>

          <blockquote class="vote-reasons-page__quote"><%= simple_format(vote.reason) %></blockquote>

          <% if vote.pending_flag? %>
            <p class="vote-reasons-page__status vote-reasons-page__status--pending">Flagged for manual review</p>
          <% elsif vote.flaggable_by?(current_user) %>
            <%= button_to "Flag this reason",
                          vote_flag_path(vote),
                          method: :post,
                          class: "vote-reasons-page__flag-button",
                          form: { data: { turbo_confirm: "Flagging an incorrect rating costs #{Vote::FLAG_COST} stardust. Continue?" } } %>
          <% end %>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="vote-reasons-page__empty">No rating reasons are available for review.</p>
  <% end %>
</main>
