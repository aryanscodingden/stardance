<% content_for :title, "Review: #{@submission.ship_event&.post&.project&.title}" %>

<%
  ship = @submission.ship_event
  project = ship&.post&.project
  builder = ship&.post&.user
  policy_obj = policy(@submission)
  can_review = policy_obj.review? && !policy_obj.try(:submitter_or_teammate?)
%>

<div class="app-layout app-layout--wide">
  <div class="app-layout__main app-layout__main--wide mission-review">
    <%= link_to "← back to queue", admin_mission_submissions_path(@mission.slug), class: "mission-review__back" %>

    <% if @reviewed_today.zero? %>
      <div class="mission-review__momentum">First review of the day. Let's go.</div>
    <% else %>
      <div class="mission-review__momentum">
        <span class="mission-review__momentum-count"><%= @reviewed_today %></span>
        reviewed today. Keep the momentum going.
      </div>
    <% end %>

    <%# Mission context bar %>
    <div class="mission-review__mission-bar">
      <% if @mission.icon.attached? %>
        <%= image_tag @mission.icon, alt: "", class: "mission-review__mission-icon" %>
      <% end %>
      <span class="mission-review__mission-name">Currently reviewing for: <%= @mission.name %></span>
    </div>

    <header class="mission-review__header">
      <div class="mission-review__title">
        <h1><%= project&.title || "—" %></h1>
        <span class="status-pill status-pill--<%= @submission.status %>"><%= @submission.status.titleize %></span>
      </div>
      <span class="mission-review__id">#<%= @submission.id %></span>
    </header>

    <div class="mission-review__body">
      <section class="mission-review__details">
        <% if @mission.submission_guide.present? %>
          <div class="mission-review__panel">
            <details>
              <summary><strong>Submission rubric</strong></summary>
              <div class="mission-review__rubric-body">
                <%= render MarkdownContentComponent.new(markdown: @mission.submission_guide, flavor: :guide) %>
              </div>
            </details>
          </div>
        <% end %>

        <% if project %>
          <div class="mission-review__panel mission-review__panel--project">
            <h2 class="mission-review__panel-title">
              Project
              <%= link_to "(open in new tab)", project_path(project), target: "_blank", rel: "noopener", class: "mission-review__panel-link" %>
            </h2>
            <iframe src="<%= project_path(project, embed: 1) %>" class="mission-review__project-iframe" loading="lazy"></iframe>
          </div>
        <% end %>

        <% if ship&.review_instructions.present? %>
          <div class="mission-review__panel">
            <h2 class="mission-review__panel-title">Review instructions</h2>
            <p><%= simple_format(ship.review_instructions.to_s) %></p>
          </div>
        <% end %>

        <div class="mission-review__panel">
          <h2 class="mission-review__panel-title">Submission</h2>
          <dl class="mission-review__meta">
            <dt>Builder</dt>
            <dd><%= builder&.display_name || "—" %></dd>
            <dt>Submitted</dt>
            <dd><%= time_ago_in_words(@submission.created_at) %> ago</dd>
            <% if @submission.pending_at.present? %>
              <dt>In queue</dt>
              <dd><%= time_ago_in_words(@submission.pending_at) %> ago</dd>
            <% end %>
            <dt>Payout path</dt>
            <dd><%= @submission.payout_path.titleize %></dd>
            <% if @submission.reviewed_by.present? %>
              <dt>Reviewer</dt>
              <dd><%= @submission.reviewed_by.display_name %></dd>
            <% end %>
            <% if @submission.submission_guide_acknowledged_at.present? %>
              <dt>Guide acknowledged</dt>
              <dd><%= @submission.submission_guide_acknowledged_at.strftime("%b %-d, %Y") %></dd>
            <% end %>
          </dl>
        </div>

        <% if @submission.rejection_message.present? %>
          <div class="mission-review__panel mission-review__panel--rejection">
            <h2 class="mission-review__panel-title">Rejection note</h2>
            <p><%= @submission.rejection_message %></p>
          </div>
        <% end %>
      </section>

      <aside class="mission-review__sidebar">
        <% if can_review && @submission.pending? && @submission.claim_held_by?(current_user) %>
          <%= render "admin/missions/submissions/form", submission: @submission, mission: @mission %>
        <% elsif can_review && @submission.pending? %>
          <div class="mission-review__claim-prompt">
            <p>You don't currently hold the claim on this review.</p>
            <%= button_to "Claim this review",
                  claim_admin_mission_submission_path(@mission.slug, @submission),
                  method: :post,
                  class: "action-btn action-btn--large action-btn--primary" %>
            <%= link_to "Back to queue", admin_mission_submissions_path(@mission.slug),
                  class: "action-btn action-btn--small action-btn--secondary" %>
          </div>
        <% elsif can_review && @submission.may_undo? %>
          <div class="mission-review__claim-prompt">
            <%= button_to "Undo decision",
                  undo_admin_mission_submission_path(@mission.slug, @submission),
                  method: :post,
                  class: "action-btn action-btn--small action-btn--secondary" %>
            <%= link_to "Back to queue", admin_mission_submissions_path(@mission.slug),
                  class: "action-btn action-btn--small action-btn--secondary" %>
          </div>
        <% else %>
          <div class="mission-review__claim-prompt">
            <%= link_to "Back to queue", admin_mission_submissions_path(@mission.slug),
                  class: "action-btn action-btn--small action-btn--secondary" %>
          </div>
        <% end %>
      </aside>
    </div>

    <% if @versions.any? %>
      <section class="mission-review__timeline">
        <h2>Timeline</h2>
        <ol class="mission-review__timeline-list">
          <% @versions.each do |v| %>
            <li class="mission-review__timeline-item">
              <span class="mission-review__timeline-when"><%= v.created_at.strftime("%b %-d, %Y %H:%M") %></span>
              <span class="mission-review__timeline-event"><%= v.event %></span>
              <% if v.whodunnit.present? %>
                <span class="mission-review__timeline-who">by <%= @whodunnit_users[v.whodunnit]&.display_name || "system" %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </section>
    <% end %>
  </div>
</div>
