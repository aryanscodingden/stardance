<% content_for :title, "Integrity Review Queue" %>

<main class="integrity-queue" role="main">
  <h1>Integrity Review Queue</h1>

  <% if @total_pending.zero? %>
    <div class="integrity-queue__empty" role="status">
      <p>No projects pending manual review.</p>
    </div>
  <% else %>
    <div class="integrity-queue__summary" role="status" aria-live="polite">
      <span class="integrity-queue__summary-label">Showing</span>
      <span class="integrity-queue__summary-count"><%= @reviews.count %></span>
    </div>

    <% if @available_flags.any? %>
      <div class="integrity-queue__filters" role="group" aria-label="Filter by flag">
        <% @available_flags.each do |flag| %>
          <% active = @selected_flags.include?(flag) %>
          <% toggled = active ? @selected_flags - [ flag ] : @selected_flags + [ flag ] %>
          <%= link_to flag.to_s.humanize,
                      admin_certification_integrity_reviews_path(flags: toggled.presence || [ "" ]),
                      class: "integrity-flags__tag integrity-flags__tag--#{flag.to_s.dasherize} integrity-queue__filter#{' is-selected' if active}",
                      aria: { pressed: active } %>
        <% end %>

        <% unless @selected_flags.sort == @available_flags.sort %>
          <%= link_to "Show all", admin_certification_integrity_reviews_path, class: "integrity-queue__filter-reset" %>
        <% end %>
      </div>
    <% end %>

    <% if @reviews.any? %>
    <div class="integrity-queue__table-container">
      <table>
        <thead>
          <tr>
            <th>Project</th>
            <th>Project ID</th>
            <th>Ship Event ID</th>
            <th>User</th>
            <th>Flags</th>
            <th>Age</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @reviews.each do |review| %>
            <% project = review.project %>
            <% shipper = review.user %>
            <tr class="<%= "integrity-queue__row--claimed" if review.claimed_by?(current_user) %>">
              <td data-label="Project">
                <% if project %>
                  <%= link_to project.title, project_path(project) %>
                <% else %>
                  <span class="integrity-queue__placeholder">—</span>
                <% end %>
              </td>
              <td data-label="Project ID"><%= project&.id || tag.span("—", class: "integrity-queue__placeholder") %></td>
              <td data-label="Ship Event ID">#<%= review.ship_event_id %></td>
              <td data-label="User">
                <% if shipper %>
                  <%= link_to shipper.display_name || "Unknown", profile_path(shipper.display_name) %>
                <% else %>
                  <span class="integrity-queue__placeholder">—</span>
                <% end %>
              </td>
              <td data-label="Flags"><%= render "flags", review: review %></td>
              <td data-label="Age">
                <% age_in_days = ((Time.current - review.ship_event.created_at) / 1.day).floor %>
                <% if age_in_days.zero? %>
                  <span class="integrity-queue__age integrity-queue__age--today">Today</span>
                <% elsif age_in_days < 7 %>
                  <span class="integrity-queue__age integrity-queue__age--recent"><%= pluralize(age_in_days, "day") %> ago</span>
                <% else %>
                  <span class="integrity-queue__age integrity-queue__age--old"><%= pluralize(age_in_days, "day") %> ago</span>
                <% end %>
              </td>
              <td data-label="Actions">
                <%= link_to "Inspect", admin_certification_integrity_review_path(review), class: "integrity-queue__inspect-btn" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% else %>
      <div class="integrity-queue__empty" role="status">
        <p>No projects match the selected flags.</p>
      </div>
    <% end %>
  <% end %>
</main>
