<% content_for :title, "Integrity Review Queue" %>

<main class="integrity-queue" role="main">
  <h1>Integrity Review Queue</h1>

  <% if @reviews.any? %>
    <div class="integrity-queue__summary" role="status" aria-live="polite">
      <span class="integrity-queue__summary-label">Pending manual review</span>
      <span class="integrity-queue__summary-count"><%= @reviews.count %></span>
    </div>

    <div class="integrity-queue__table-container">
      <table>
        <thead>
          <tr>
            <th>Project</th>
            <th>Project ID</th>
            <th>Ship Event ID</th>
            <th>User</th>
            <th>Age</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @reviews.each do |review| %>
            <% project = review.project %>
            <% shipper = review.user %>
            <tr>
              <td data-label="Project">
                <% if project %>
                  <%= link_to project.title, project_path(project) %>
                <% else %>
                  <span class="integrity-queue__placeholder">—</span>
                <% end %>
              </td>
              <td data-label="Project ID"><%= project&.id || tag.span("—", class: "integrity-queue__placeholder") %></td>
              <td data-label="Ship Event ID">#<%= review.ship_event_id %></td>
              <td data-label="User">
                <% if shipper %>
                  <%= link_to shipper.display_name || "Unknown", profile_path(shipper.display_name) %>
                <% else %>
                  <span class="integrity-queue__placeholder">—</span>
                <% end %>
              </td>
              <td data-label="Age">
                <% age_in_days = ((Time.current - review.ship_event.created_at) / 1.day).floor %>
                <% if age_in_days.zero? %>
                  <span class="integrity-queue__age integrity-queue__age--today">Today</span>
                <% elsif age_in_days < 7 %>
                  <span class="integrity-queue__age integrity-queue__age--recent"><%= pluralize(age_in_days, "day") %> ago</span>
                <% else %>
                  <span class="integrity-queue__age integrity-queue__age--old"><%= pluralize(age_in_days, "day") %> ago</span>
                <% end %>
              </td>
              <td data-label="Actions">
                <%= link_to "Inspect", admin_certification_integrity_review_path(review), class: "integrity-queue__inspect-btn" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="integrity-queue__empty" role="status">
      <p>No projects pending manual review.</p>
    </div>
  <% end %>
</main>
