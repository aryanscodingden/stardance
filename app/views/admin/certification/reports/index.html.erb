<% content_for :title, "Project Reports" %>

<main>
  <h1>Project Reports</h1>

  <div class="admin-actions-wrap">
    <span class="badge badge-pending"><%= @counts[:pending] %> Pending</span>
    <span class="badge badge-active"><%= @counts[:reviewed] %> Reviewed</span>
    <span class="badge badge-archived"><%= @counts[:dismissed] %> Dismissed</span>
    <%= button_to "Process Demo Broken", process_demo_broken_admin_certification_reports_path, method: :post,
        class: "btn-secondary slim",
        data: { confirm: "This will auto-review projects with 5+ pending demo_broken reports and re-certify them. Continue?" } %>
  </div>

  <div class="flex">
    <section class="admin-section">
      <h3 class="admin-section__header">Filters</h3>
      <%= form_with url: admin_certification_reports_path, method: :get, local: true do |f| %>
        <div class="admin-filters__row">
          <div class="admin-filters__field">
            <%= f.label :status, "Status", class: "admin-filters__label" %>
            <%= f.select :status, options_for_select([["Pending", "pending"], ["Reviewed", "reviewed"], ["Dismissed", "dismissed"]], params.key?(:status) ? params[:status] : "pending"), { include_blank: "All" }, { onchange: "this.form.requestSubmit()", class: "admin-filters__select" } %>
          </div>
          <div class="admin-filters__field">
            <%= f.label :reason, "Reason", class: "admin-filters__label" %>
            <%= f.select :reason, options_for_select(Project::Report::REASONS.map { |r| [r.titleize, r] }, params[:reason]), { include_blank: "All" }, { onchange: "this.form.requestSubmit()", class: "admin-filters__select" } %>
          </div>
        </div>
      <% end %>
    </section>

  </div>

  <section class="admin-section">
    <% if @reports.any? %>
      <table class="space-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Project</th>
            <th>Reporter</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Actioned By</th>
            <th>Age</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @reports.each do |report| %>
            <tr>
              <td><code>#<%= report.id %></code></td>
              <td>
                <% if report.project %>
                  <%= link_to report.project.title, admin_project_path(report.project) %>
                <% else %>
                  <span>(Deleted)</span>
                <% end %>
              </td>
              <td>
                <div class="admin-actions-wrap">
                  <img src="<%= report.reporter.avatar %>" alt="" style="width:24px;height:24px;border-radius:50%;">
                  <%= link_to report.reporter.display_name, admin_user_path(report.reporter) %>
                </div>
              </td>
              <td>
                <span class="badge"><%= report.reason.titleize %></span>
              </td>
              <td>
                <% badge_class = report.status == "reviewed" ? "badge-active" : report.status == "dismissed" ? "badge-archived" : "badge-pending" %>
                <span class="badge <%= badge_class %>"><%= report.status %></span>
              </td>
              <td>
                <% reviewer_info = @reviewers_by_report[report.id] %>
                <% if reviewer_info.is_a?(User) %>
                  <div class="admin-actions-wrap">
                    <img src="<%= reviewer_info.avatar %>" alt="" style="width:24px;height:24px;border-radius:50%;">
                    <span><%= reviewer_info.display_name %></span>
                  </div>
                <% elsif reviewer_info == :auto %>
                  <span class="badge badge-active">Auto</span>
                <% else %>
                  <span>—</span>
                <% end %>
              </td>
              <td title="<%= report.created_at.strftime('%Y-%m-%d %H:%M') %>">
                <%= time_ago_in_words(report.created_at) %> ago
              </td>
              <td>
                <%= link_to "View", admin_certification_report_path(report), class: "btn-primary slim" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No reports found matching your filters.</p>
    <% end %>
  </section>

  <%= link_to "← Back to Users", admin_users_path, class: "btn-secondary slim" %>
</main>
