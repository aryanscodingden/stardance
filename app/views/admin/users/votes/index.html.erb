<% content_for :title, "Votes by #{@user.display_name}" %>
<h1 align="center">Votes by <%= @user.display_name %></h1>

<div>
  <%= link_to "← Back to User", admin_user_path(@user) %>
  <label>
    <input type="checkbox" id="toggle-reasons" checked>
    Show vote reasons
  </label>
</div>

<div>
  <% if @votes.any? %>
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Project</th>
          <th>Orig.</th>
          <th>Tech.</th>
          <th>Usab.</th>
          <th>Story.</th>
          <th>Time spent</th>
          <th>Status</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% @votes.each do |vote| %>
          <tr>
            <td><%= time_ago_in_words(vote.created_at) %> ago</td>
            <td>
              <% if vote.project %>
                <%= link_to truncate(vote.project.title, length: 30), admin_project_path(vote.project) %>
              <% else %>
                <span>Deleted</span>
              <% end %>
            </td>
            <td><%= vote.originality_score || "—" %></td>
            <td><%= vote.technical_score || "—" %></td>
            <td><%= vote.usability_score || "—" %></td>
            <td><%= vote.storytelling_score || "—" %></td>
            <td><%= vote_duration_in_words(vote.time_taken_to_vote_in_seconds) %></td>
            <td><%= vote.discarded? ? "Discarded" : "Counted" %></td>
            <td class="vote-reasons">
              <% if vote.reason.present? %>
                <details>
                  <summary>View</summary>
                  <div><%= vote.reason %></div>
                </details>
              <% else %>
                <span>—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @pagy.pages > 1 %>
      <div>
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% else %>
    <p>No votes cast yet.</p>
  <% end %>
</div>

<script>
  (function() {
    const toggle = document.getElementById("toggle-reasons");
    if (!toggle) return;

    const setReasonsExpanded = (expanded) => {
      document.querySelectorAll("td.vote-reasons details").forEach((details) => {
        details.open = expanded;
      });
    };
    setReasonsExpanded(toggle.checked);
    toggle.addEventListener("change", function() {
      setReasonsExpanded(this.checked);
    });
  })();
</script>
