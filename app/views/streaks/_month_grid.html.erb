<div class="streak-widget__cal-nav">
  <% if local_assigns.fetch(:show_prev, true) %>
    <button type="button" class="streak-widget__cal-nav-btn" data-action="streak#prevMonth" aria-label="Previous month">‹</button>
  <% else %>
    <span class="streak-widget__cal-nav-btn streak-widget__cal-nav-btn--disabled">‹</span>
  <% end %>
  <span class="streak-widget__cal-month"><%= date.strftime("%B %Y") %></span>
  <% if show_next %>
    <button type="button" class="streak-widget__cal-nav-btn" data-action="streak#nextMonth" aria-label="Next month">›</button>
  <% else %>
    <span class="streak-widget__cal-nav-btn streak-widget__cal-nav-btn--disabled">›</span>
  <% end %>
</div>

<div class="streak-widget__cal-grid">
  <% %w[S M T W T F S].each do |d| %>
    <div class="streak-widget__cal-day-header"><%= d %></div>
  <% end %>

  <% calendar_days.each do |day| %>
    <div class="streak-widget__cal-cell <%= "streak-widget__cal-cell--outside" unless day[:in_month] %>"
         <% if day[:in_month] && day[:coded_seconds] > 0 && !day[:future] %>
           data-controller="tooltip"
           data-tooltip-message-value="<%= day[:coded_seconds] / 60 %> minutes"
         <% end %>>
      <% if day[:streak_left] || day[:streak_right] %>
        <div class="streak-widget__cal-bar
                    <%= "streak-widget__cal-bar--left" if day[:streak_left] %>
                    <%= "streak-widget__cal-bar--right" if day[:streak_right] %>"></div>
      <% end %>
      <% if day[:in_month] %>
        <% if day[:completed] %>
          <%= image_tag "streak/star_filled.svg", class: "streak-widget__cal-star", alt: "" %>
        <% else %>
          <%= image_tag "streak/star_empty.svg", class: "streak-widget__cal-star", alt: "" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
