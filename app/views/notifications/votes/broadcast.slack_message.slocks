voter_label = voter_slack_id.present? ? "<@#{voter_slack_id}>" : voter_name

section "#{voter_label} rated <#{project_url}|#{project_title}>\nOriginality: #{originality_score} · Technicality: #{technical_score} · Usability: #{usability_score} · Storytelling: #{storytelling_score} · <#{votes_url}|voting booth>", markdown: true

if reason.present?
  context [
    mrkdwn_text(":speech_balloon: #{reason}")
  ]
end
